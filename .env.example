# ============================================
# Configuración de Base de Datos (Neon Postgres)
# ============================================

# URL de conexión principal (con pgbouncer)
DATABASE_URL=postgresql://usuario:password@host-pooler.region.neon.tech/dbname?sslmode=require

# URL sin pooling (para migraciones)
DATABASE_URL_UNPOOLED=postgresql://usuario:password@host.region.neon.tech/dbname?sslmode=require

# ============================================
# NextAuth.js (Autenticación)
# ============================================

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=tu_secreto_seguro_generar_con_openssl_rand_base64_32

# OAuth - Google
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# OAuth - GitHub
GITHUB_ID=tu_github_oauth_id
GITHUB_SECRET=tu_github_oauth_secret

# ============================================
# Stripe (Pagos - Futuro)
# ============================================

STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Configuración de la aplicación
# ============================================

# Entorno: development | production
NODE_ENV=development

# Puerto (opcional, para desarrollo local)
PORT=3000
