# ============================================
# Configuración de Base de Datos (Neon Postgres)
# ============================================

# URL de conexión principal (con pgbouncer)
DATABASE_URL=postgresql://usuario:password@host-pooler.region.neon.tech/dbname?sslmode=require

# URL sin pooling (para migraciones)
DATABASE_URL_UNPOOLED=postgresql://usuario:password@host.region.neon.tech/dbname?sslmode=require

# ============================================
# NextAuth.js (Autenticación)
# ============================================

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=tu_secreto_seguro_generar_con_openssl_rand_base64_32

# OAuth - Google
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# OAuth - GitHub
GITHUB_ID=tu_github_oauth_id
GITHUB_SECRET=tu_github_oauth_secret

# ============================================
# Stripe (Pagos - Futuro)
# ============================================

STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Configuración de la aplicación
# ============================================

# Entorno: development | production | test
NODE_ENV=development

# Puerto (opcional, para desarrollo local)
PORT=3000

# ============================================
# Configuración de Testing
# ============================================

# Base de datos para tests (opcional)
TEST_DATABASE_URL=postgresql://usuario:password@host-pooler.region.neon.tech/test_dbname?sslmode=require

# ============================================
# Configuración de Features
# ============================================

# Habilitar/deshabilitar features (true | false)
ENABLE_ANALYTICS=false
ENABLE_NEWSLETTER=false
ENABLE_COMMENTS=false

# ============================================
# Runtimes browser-only (Wasmer)
# ============================================

# Go y Bash usan paquetes runtime fijos internos del sistema:
# - golang/go@1.25.5-wasix-1 (con fallback a golang/go)
# - wasmer/bash@1.0.25 (con fallback a wasmer/bash)
# Clojure/Rust se configuran directamente en código:
# components/python-editor/wasm-language-runtime.ts
